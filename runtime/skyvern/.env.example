ENV=local

BROWSER_TYPE=chromium-headful
BROWSER_STREAMING_MODE=cdp
BROWSER_ACTION_TIMEOUT_MS=10000

GETJOBS_LLM_PROVIDER="openai-compatible"
ENABLE_OPENAI_COMPATIBLE=true
OPENAI_COMPATIBLE_MODEL_KEY=OPENAI_COMPATIBLE
OPENAI_COMPATIBLE_MODEL_NAME="deepseek-chat"
OPENAI_COMPATIBLE_API_KEY="your-api-key"
OPENAI_COMPATIBLE_API_BASE="https://api.deepseek.com/v1"
OPENAI_COMPATIBLE_SUPPORTS_VISION=false
OPENAI_COMPATIBLE_MAX_TOKENS=4096
MIMO_API_KEY=""

LLM_KEY=OPENAI_COMPATIBLE
SECONDARY_LLM_KEY=OPENAI_COMPATIBLE
MAX_STEPS_PER_RUN=10000
MAX_STEPS_PER_TASK_V2=10000

DATABASE_STRING=sqlite+aiosqlite:///./data/skyvern.db
LOG_LEVEL=INFO
PORT=8001
SKYVERN_TELEMETRY=false
SKYVERN_API_KEY=""
